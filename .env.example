# Runtime connection used by the Next.js app.
# Supabase + Vercel: use Supavisor transaction pooler on port 6543.
# Example:
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/industrial_con_j?schema=public"

# Direct or session connection used for Prisma migrations and one-off admin jobs.
# Supabase: prefer direct db.[PROJECT_REF].supabase.co:5432 when available, or session pooler on port 5432.
# Example:
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/industrial_con_j?schema=public"

JWT_SECRET="replace-with-a-long-random-secret"
ADMIN_LOGIN_EMAIL="ignacio.alarcon.s@uchile.cl"
ADMIN_LOGIN_PASSWORD="000000"
ADMIN_SEED_EMAIL="admin@industrialconj.com"
ADMIN_SEED_PASSWORD="change-this-before-seeding"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
