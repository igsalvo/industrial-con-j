  sponsorsSectionEyebrow      String?  @default("Sponsors")
  sponsorsSectionTitle        String?  @default("Marcas alineadas con la industria")
  sponsorsSectionDescription  String?  @default("Espacio para patrocinadores destacados y oportunidades de partnership por episodio.")
  sponsorsSectionOrder        Int      @default(3)
  donationsSectionEyebrow     String?  @default("Donaciones")
  donationsSectionTitle       String?  @default("Apoya nuevas conversaciones industriales")
  donationsSectionDescription String?  @default("Deja tus datos para coordinar una donacion, alianza o apoyo al proyecto.")
  donationsSectionOrder       Int      @default(4)
  donationUrl                 String?
  recommendedSectionEyebrow   String?  @default("Recomendados")
  recommendedSectionTitle     String?  @default("Episodios que merecen otra escucha")
  recommendedSectionDescription String? @default("Selecciones editoriales para facilitar descubrimiento y aumentar tiempo de sesion.")
  recommendedSectionOrder     Int      @default(4)
  guestsSectionEyebrow        String?  @default("Invitados")
  guestsSectionTitle          String?  @default("Voces del ecosistema industrial")
  guestsSectionDescription    String?  @default("Expertos, operadores y lideres que aterrizan teoria en ejecucion.")
  guestsSectionOrder          Int      @default(5)
  identitySectionEyebrow      String?  @default("Identidad")
  identitySectionTitle        String?  @default("Lo que mueve Industrial con J")
