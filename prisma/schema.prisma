  heroOrder                   Int      @default(0)
  featuredClipsEyebrow        String?  @default("Clips destacados")
  featuredClipsTitle          String?  @default("Shorts de los capitulos")
  featuredClipsDescription    String?  @default("Fragmentos cortos para destacar ideas clave y llevar trafico al episodio completo.")
