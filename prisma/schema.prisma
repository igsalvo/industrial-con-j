  honorSectionEyebrow         String?  @default("Alumni")
  honorSectionTitle           String?  @default("Personas que abren camino")
  honorSectionDescription     String?  @default("Reconocimientos y perfiles destacados del ecosistema industrial.")
  honorSectionOrder           Int      @default(7)
  productsSectionEyebrow      String?  @default("TienDIIta CEIN")
  productsSectionTitle        String?  @default("Catálogo simple")
