  episodesPageEyebrow         String?  @default("Archivo")
  episodesPageTitle           String?  @default("Todos los episodios")
  episodesPageDescription     String?  @default("Explora el catalogo completo con lecturas limpias, links externos y relacion entre invitados, tags e industrias.")
  guestsPageEyebrow           String?  @default("Invitados")
  guestsPageTitle             String?  @default("Personas que construyen industria")
  guestsPageDescription       String?  @default("Perfiles, empresas, enlaces sociales y episodios donde participan.")
  sponsorsPageEyebrow         String?  @default("Sponsors")
  sponsorsPageTitle           String?  @default("Aliados comerciales del podcast")
  sponsorsPageDescription     String?  @default("Grid de logos, links de salida y sponsor destacado por episodio.")
