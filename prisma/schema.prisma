  showSponsorsSection         Boolean  @default(true)
  showRecommendedSection      Boolean  @default(true)
  showGuestsSection           Boolean  @default(true)
  showIdentitySection         Boolean  @default(true)
  showHonorSection            Boolean  @default(true)
  showProductsSection         Boolean  @default(true)
  showEventsSection           Boolean  @default(true)
  showParticipationSection    Boolean  @default(true)
  showCommunityLink           Boolean  @default(true)
  showDonationsSection        Boolean  @default(true)
  showSponsorBanner           Boolean  @default(true)
