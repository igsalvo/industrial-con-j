  productsSectionOrder        Int      @default(8)
  eventsSectionEyebrow        String?  @default("Eventos")
  eventsSectionTitle          String?  @default("Próximas actividades")
  eventsSectionDescription    String?  @default("Calendario de encuentros, hitos y actividades abiertas para la comunidad.")
