model MediaItem {
  id        String   @id @default(cuid())
  section   String
  src       String
  alt       String
  label     String?
  href      String?
  positionX String  @default("center")
  positionY String  @default("center")
  order     Int     @default(0)
  isFeatured Boolean @default(false)
  isVisible Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section, isVisible, order])
}

model IdentityItem {
  id        String   @id @default(cuid())
  kind      String
  title     String
  text      String
  icon      String?
  imageUrl  String?
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, order])
  @@index([isVisible, order])
}

model HonorMember {
  id            String   @id @default(cuid())
  name          String
  photoUrl      String?
  photoPositionX Int     @default(50)
  photoPositionY Int     @default(50)
  description   String
  role          String?
  generation    String?
  externalLinks Json?
  order         Int      @default(0)
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isVisible, order])
}

model NewsItem {
  id                 String   @id @default(cuid())
  slug               String   @unique
  title              String
  excerpt            String
  body               String
  imageUrl           String?
  imagePositionX     String   @default("center")
  imagePositionY     String   @default("center")
  tags               String[]
  ctaText            String?
  ctaLink            String?
  publishedAt        DateTime @default(now())
  order              Int      @default(0)
  showOnNews         Boolean  @default(true)
  showOnAlumniNews   Boolean  @default(false)
  isVisible          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isVisible, showOnNews, publishedAt])
  @@index([isVisible, showOnAlumniNews, publishedAt])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  order       Int       @default(0)
  isVisible   Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isVisible, order])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  photoUrl    String?
  photoUrls   Json             @default("[]")
  photoPositionX String @default("center")
  photoPositionY String @default("center")
  description String
  price       Decimal          @db.Decimal(10, 2)
  stock       Int?
  ctaText     String?
  ctaLink     String?
  order       Int              @default(0)
  isVisible   Boolean          @default(true)
  categoryId  String
  category    ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([categoryId])
  @@index([isVisible, order])
}

model ParticipationItem {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  icon        String?
  type        String
  ctaText     String?
  ctaLink     String?
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, order])
  @@index([isVisible, order])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  imageUrl    String?
  imagePositionX String @default("center")
  imagePositionY String @default("center")
  sourceName  String?
  sourceLogoUrl String?
  sourceCalendarUrl String?
  type        String?
  ctaText     String?
  ctaLink     String?
  order       Int       @default(0)
  isFeatured  Boolean   @default(false)
  isVisible   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isVisible, startsAt])
  @@index([startsAt])
}

model CalendarSource {
  id              String   @id @default(cuid())
  name            String
  calendarIdOrUrl String
  logoUrl         String?
  order           Int      @default(0)
  isVisible       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isVisible, order])
}
