model IdentityItem {
  id        String   @id @default(cuid())
  kind      String
  title     String
  text      String
  icon      String?
  imageUrl  String?
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, order])
  @@index([isVisible, order])
}

model HonorMember {
  id            String   @id @default(cuid())
  name          String
  photoUrl      String?
  description   String
  role          String?
  generation    String?
  externalLinks Json?
  order         Int      @default(0)
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isVisible, order])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  order       Int       @default(0)
  isVisible   Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isVisible, order])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  photoUrl    String?
  description String
  price       Decimal          @db.Decimal(10, 2)
  stock       Int?
  ctaText     String?
  ctaLink     String?
  order       Int              @default(0)
  isVisible   Boolean          @default(true)
  categoryId  String
  category    ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([categoryId])
  @@index([isVisible, order])
}

model ParticipationItem {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  icon        String?
  type        String
  ctaText     String?
  ctaLink     String?
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, order])
  @@index([isVisible, order])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  imageUrl    String?
  type        String?
  ctaText     String?
  ctaLink     String?
  order       Int       @default(0)
  isVisible   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isVisible, startsAt])
  @@index([startsAt])
}
